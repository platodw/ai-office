{
  "manifest_version": 3,
  "name": "AI Office",
  "version": "0.1.0",
  "description": "Connect to Claude Desktop for guided setup and AI-assisted work — right from your browser",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src * data:; connect-src http://127.0.0.1:7848 http://127.0.0.1:7847 https://aioffice.app"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "AI Office",
    "default_icon": {
      "16": "icons/default_16.png",
      "32": "icons/default_32.png",
      "48": "icons/default_48.png",
      "128": "icons/default_128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/default_16.png",
    "32": "icons/default_32.png",
    "48": "icons/default_48.png",
    "128": "icons/default_128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
